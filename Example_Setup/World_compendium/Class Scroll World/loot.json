{
  "root": "categoryPick",
  "nodes": {
    "categoryPick": {
      "kind": "pick",
      "axis": "category",
      "weights": {
        "scroll": 60,
        "iron-bits": 30,
        "magic-item": 10
      },
      "branches": {
        "scroll": "scrollRecipe",
        "iron-bits": "currencyRarityPick",
        "magic-item": "gearRarityPick"
      }
    },
    "scrollRecipe": {
      "kind": "pick",
      "axis": "rarityClass",
      "weights": {
        "plain": 80,
        "rare": 18,
        "unique": 2
      },
      "branches": {
        "plain": "scrollPlainDomainPick",
        "rare": "scrollRareDomainPick",
        "unique": "scrollUniqueDomainPick"
      }
    },
    "scrollPlainDomainPick": {
      "kind": "pick",
      "axis": "domain",
      "weights": {
        "combat": 50,
        "nonCombat": 50
      },
      "branches": {
        "combat": "scrollPlainDraw",
        "nonCombat": "scrollPlainDraw"
      }
    },
    "scrollPlainDraw": {
      "kind": "draw",
      "draws": [
        {
          "pool": "jobList",
          "as": "job",
          "filterBy": "domain"
        }
      ],
      "next": "scrollPlainCompose"
    },
    "scrollPlainCompose": {
      "kind": "compose",
      "template": "{job}"
    },
    "scrollRareDomainPick": {
      "kind": "pick",
      "axis": "domain",
      "weights": {
        "combat": 50,
        "nonCombat": 50
      },
      "branches": {
        "combat": "scrollRareDraw",
        "nonCombat": "scrollRareDraw"
      }
    },
    "scrollRareDraw": {
      "kind": "draw",
      "draws": [
        {
          "pool": "rareJobList",
          "as": "job",
          "filterBy": "domain"
        },
        {
          "pool": "aspectList",
          "as": "aspect"
        }
      ],
      "next": "scrollRareCompose"
    },
    "scrollRareCompose": {
      "kind": "compose",
      "template": "{job} of the {aspect}"
    },
    "scrollUniqueDomainPick": {
      "kind": "pick",
      "axis": "domain",
      "weights": {
        "combat": 50,
        "nonCombat": 50
      },
      "branches": {
        "combat": "scrollUniqueDraw",
        "nonCombat": "scrollUniqueDraw"
      }
    },
    "scrollUniqueDraw": {
      "kind": "draw",
      "draws": [
        {
          "pool": "uniqueList",
          "as": "job",
          "filterBy": "domain"
        }
      ],
      "next": "scrollUniqueCompose"
    },
    "scrollUniqueCompose": {
      "kind": "compose",
      "template": "{job}"
    },
    "currencyRarityPick": {
      "kind": "pick",
      "axis": "currencyRarity",
      "weights": {
        "small": 70,
        "mid": 25,
        "large": 5
      },
      "branches": {
        "small": "currencySmallAmount",
        "mid": "currencyMidAmount",
        "large": "currencyLargeAmount"
      }
    },
    "currencySmallAmount": {
      "kind": "amount",
      "unit": "iron bits",
      "min": 1,
      "max": 20,
      "next": "currencyCompose"
    },
    "currencyMidAmount": {
      "kind": "amount",
      "unit": "iron bits",
      "min": 20,
      "max": 80,
      "next": "currencyCompose"
    },
    "currencyLargeAmount": {
      "kind": "amount",
      "unit": "iron bits",
      "min": 80,
      "max": 300,
      "next": "currencyCompose"
    },
    "currencyCompose": {
      "kind": "compose",
      "template": "{iron bits} iron bits"
    },
    "gearRarityPick": {
      "kind": "pick",
      "axis": "gearRarity",
      "weights": {
        "common": 75,
        "uncommon": 20,
        "rare": 5
      },
      "branches": {
        "common": "gearCommonDraw",
        "uncommon": "gearUncommonDraw",
        "rare": "gearRareDraw"
      }
    },
    "gearCommonDraw": {
      "kind": "draw",
      "draws": [
        {
          "pool": "commonGearPool",
          "as": "item"
        }
      ],
      "next": "gearCommonCompose"
    },
    "gearCommonCompose": {
      "kind": "compose",
      "template": "{item}"
    },
    "gearUncommonDraw": {
      "kind": "draw",
      "draws": [
        {
          "pool": "uncommonGearPool",
          "as": "item"
        }
      ],
      "next": "gearUncommonCompose"
    },
    "gearUncommonCompose": {
      "kind": "compose",
      "template": "{item}"
    },
    "gearRareDraw": {
      "kind": "draw",
      "draws": [
        {
          "pool": "rareGearPool",
          "as": "item"
        }
      ],
      "next": "gearRareCompose"
    },
    "gearRareCompose": {
      "kind": "compose",
      "template": "{item}"
    }
  },
